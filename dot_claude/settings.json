{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_UPDATE": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(adb *)",
      "Bash(brew list:*)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(fd *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh api *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Bash(git blame *)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote -v)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git status *)",
      "Bash(git tag *)",
      "Bash(glab mr checkout:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab mr view:*)",
      "Bash(grep *)",
      "Bash(gs branch:*)",
      "Bash(gs log:*)",
      "Bash(head *)",
      "Bash(java *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(tmux display-message:*)",
      "Bash(tmux list-panes:*)",
      "Bash(unzip * ~/.gradle/caches/*)",
      "Bash(wc *)",
      "Bash(which *)",
      "Edit(~/.config/ai/docs/*)",
      "LSP",
      "Read(~/.config/ai/docs/*)",
      "TaskUpdate(~/.config/ai/docs/*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Write(~/.config/ai/docs/*)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git branch -D *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "clangd-lsp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "prefersReducedMotion": false,
  "showThinkingSummaries": true,
  "autoConnectIde": true
}
