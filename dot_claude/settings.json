{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "0",
    "CLAUDE_CODE_DISABLE_ALTERNATE_SCREEN": "0",
    "CLAUDE_CODE_DISABLE_AUTO_UPDATE": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "ENABLE_LSP_TOOL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(./fetch-pipeline.sh:*)",
      "Bash(./gradlew *)",
      "Bash(adb *)",
      "Bash(bash ~/.ai/*)",
      "Bash(bash ~/.config/ai/bin/*)",
      "Bash(brew list:*)",
      "Bash(cat *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(fd *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh api *)",
      "Bash(gh issue view *)",
      "Bash(gh pr view *)",
      "Bash(git blame *)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git remote -v)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(git status *)",
      "Bash(git tag *)",
      "Bash(git-spice branch:*)",
      "Bash(git-spice log:*)",
      "Bash(glab mr checkout:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab mr view:*)",
      "Bash(grep *)",
      "Bash(gs branch:*)",
      "Bash(gs log:*)",
      "Bash(head *)",
      "Bash(java *)",
      "Bash(ksrc *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(tmux display-message:*)",
      "Bash(tmux list-panes:*)",
      "Bash(unzip * ~/.gradle/caches/*)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(~/.ai/*)",
      "Edit(~/.ai/*)",
      "LSP",
      "Read(~/.ai/*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "deny": [
      "Bash(git branch -D *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/*.lock)",
      "Edit(**/gradle.lockfile)",
      "Edit(**/build/**)",
      "Edit(**/generated/**)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "fallbackModel": [
    "claude-opus-4-7",
    "claude-opus-4-6"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/ai/skills/doc/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/ai/skills/doc/hooks/stop.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/ai/skills/doc/hooks/precompact.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 5,
    "hideVimModeIndicator": true
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "bash ~/.claude/subagent-statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "chrisbanes-skills@chrisbanes-skills": false,
    "clangd-lsp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "ksrc@respawn-tools": false,
    "lua-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "chrisbanes-skills": {
      "source": {
        "source": "github",
        "repo": "chrisbanes/skills"
      }
    },
    "respawn-tools": {
      "source": {
        "source": "github",
        "repo": "respawn-app/claude-plugin-marketplace"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "prefersReducedMotion": false,
  "showThinkingSummaries": true,
  "theme": "auto",
  "preferredNotifChannel": "notifications_disabled",
  "skipAutoPermissionPrompt": true,
  "autoConnectIde": false,
  "model": "opus"
}
