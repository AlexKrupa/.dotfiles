#!/bin/bash
# BetterDisplay sharing control script

CACHE_DIR="$HOME/.config/share-focus/.cache"
ENABLED_FILE="$CACHE_DIR/sharing-enabled"

VIRTUAL_DISPLAY="Sharing"
BD="/Applications/BetterDisplay.app/Contents/MacOS/BetterDisplay"

# Defaults for start args
ASPECT="16:9"
DOWNSCALE=1

# Function to detect main display
detect_main_display() {
    # Get all display names from JSON output
    local display_names=$($BD get -identifiers | grep '"name"' | grep -v 'VirtualScreen\|DisplayGroup' | sed 's/.*"name" : "\([^"]*\)".*/\1/')

    # Check each display to find the main one
    while IFS= read -r display_name; do
        if [ -n "$display_name" ]; then
            local is_main=$($BD get -name="$display_name" -main)
            if [ "$is_main" = "true" ]; then
                echo "$display_name"
                return
            fi
        fi
    done <<< "$display_names"
}

# Function to ensure sync executable is available
ensure_sync_executable() {
    local sync_path="$HOME/.config/share-focus/sync"
    local swift_path="$HOME/.config/share-focus/sync.swift"

    if [ ! -f "$sync_path" ]; then
        if [ -f "$swift_path" ]; then
            echo "Compiling sync executable"
            swiftc "$swift_path" -o "$sync_path"
            if [ $? -ne 0 ]; then
                echo "Error: Failed to compile sync executable"
                return 1
            fi
        else
            echo "Error: sync.swift not found"
            return 1
        fi
    fi
    return 0
}

# Function to ensure virtual display exists
ensure_virtual_display() {
    # Check if virtual display exists by trying to get its info
    local display_exists=$($BD get -identifiers | grep "\"name\" : \"$VIRTUAL_DISPLAY\"")

    if [ -z "$display_exists" ]; then
        echo "Creating virtual display: $VIRTUAL_DISPLAY"
        $BD create -type=VirtualScreen -virtualScreenName="$VIRTUAL_DISPLAY"
        if [ $? -ne 0 ]; then
            echo "Error: Failed to create virtual display"
            return 1
        fi
    fi
    return 0
}

# Compute virtual display resolution from source display, aspect ratio, and downscale
compute_virtual_resolution() {
    local src_w=$1 src_h=$2 asp_w=$3 asp_h=$4 ds=$5

    # Fit source into target aspect ratio (bounding box containing source)
    local from_width=$((src_w * asp_h))
    local from_height=$((src_h * asp_w))

    local target_w
    if [ "$from_width" -ge "$from_height" ]; then
        target_w=$src_w
    else
        target_w=$((src_h * asp_w / asp_h))
    fi
    local target_h=$((target_w * asp_h / asp_w))

    echo "$((target_w / ds))x$((target_h / ds))"
}

# Function to start sharing
start() {
    # Ensure sync executable is available
    if ! ensure_sync_executable; then
        return 1
    fi

    # Ensure virtual display exists
    if ! ensure_virtual_display; then
        return 1
    fi

    # Detect main display
    echo "Detecting main display"
    MAIN_DISPLAY=$(detect_main_display)

    if [ -z "$MAIN_DISPLAY" ]; then
        echo "Error: No main display found"
        return 1
    fi

    echo "Found main display: $MAIN_DISPLAY"

    # Get source resolution and compute virtual display resolution
    local src_resolution=$($BD get -name="$MAIN_DISPLAY" -resolution)
    local src_w=$(echo "$src_resolution" | cut -dx -f1)
    local src_h=$(echo "$src_resolution" | cut -dx -f2)
    local asp_w=$(echo "$ASPECT" | cut -d: -f1)
    local asp_h=$(echo "$ASPECT" | cut -d: -f2)

    local virtual_res=$(compute_virtual_resolution "$src_w" "$src_h" "$asp_w" "$asp_h" "$DOWNSCALE")

    echo "Virtual display: ${virtual_res} (source ${src_resolution}, aspect ${ASPECT}, downscale ${DOWNSCALE})"

    # Set virtual display resolution before connecting
    # (resolution set prints "Failed." on disconnected displays but works)
    $BD set -name="$VIRTUAL_DISPLAY" -useResolutionList=on -resolutionList="$virtual_res"
    $BD set -name="$VIRTUAL_DISPLAY" -resolution="$virtual_res" > /dev/null 2>&1

    # Connect the virtual display
    echo "Connecting virtual display: $VIRTUAL_DISPLAY"
    $BD set -name="$VIRTUAL_DISPLAY" -connected=on

    # Wait for virtual display to initialize
    sleep 0.5

    # Stream from main to virtual display
    echo "Streaming $MAIN_DISPLAY → $VIRTUAL_DISPLAY"
    $BD set -name="$MAIN_DISPLAY" -stream=on -targetName="$VIRTUAL_DISPLAY"

    # Write source display info for sync
    echo "$MAIN_DISPLAY|$(echo "$src_resolution" | sed 's/x/ /')" > "$ENABLED_FILE"

    # Initial run
    ~/.config/share-focus/sync

    echo "Sharing enabled"
}

# Function to stop sharing
stop() {
    # Disconnect the virtual display and remove flag
    echo "Disconnecting virtual display: $VIRTUAL_DISPLAY"
    $BD set -name="$VIRTUAL_DISPLAY" -connected=off

    rm -f "$ENABLED_FILE"
    echo "Sharing disabled"
}

mkdir -p "$CACHE_DIR"

parse_start_args() {
    shift  # consume "start"
    while [ $# -gt 0 ]; do
        case "$1" in
            --aspect=*) ASPECT="${1#--aspect=}" ;;
            --aspect)   ASPECT="$2"; shift ;;
            --downscale=*) DOWNSCALE="${1#--downscale=}" ;;
            --downscale)   DOWNSCALE="$2"; shift ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
        shift
    done
}

case "$1" in
    start)
        parse_start_args "$@"
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        parse_start_args "$@"
        start
        ;;
    status)
        if [ -f "$ENABLED_FILE" ]; then
            echo "Sharing enabled"
        else
            echo "Sharing disabled"
        fi
        ;;
    "")
        # Toggle: start if stopped, stop if started
        if [ -f "$ENABLED_FILE" ]; then
            stop
        else
            start
        fi
        ;;
    *)
        echo "Usage: service {start [--aspect W:H] [--downscale N]|stop|restart [--aspect W:H] [--downscale N]|status}"
        exit 1
        ;;
esac
