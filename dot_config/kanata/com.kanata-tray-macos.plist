<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kanata-tray-macos</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/alexkrupa/.config/kanata/kanata-tray-macos</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>ThrottleInterval</key>
    <integer>20</integer>
    <key>StandardOutPath</key>
    <string>/tmp/kanata-tray.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/kanata-tray.stderr.log</string>
</dict>
</plist>
